# Copy this file to `.env` and fill in real values.
# `.env` is git-ignored and must NEVER be committed.
#
# WARNING: Vite exposes any VITE_* variable in the browser bundle. The AI
# API key below ships to every client visiting the site. For production, move
# this call behind a server proxy and keep the key server-side.

# AI extraction API key
VITE_AI_API_KEY=

# AI model name (e.g. a vision-capable model identifier supplied by your provider)
VITE_AI_MODEL=

# Soft rate-limit cap (requests per minute). The client throttles outgoing
# AI calls to stay under this number. Default 18 — set to your actual
# quota minus a small buffer (free tier is typically 20 RPM).
VITE_AI_RPM=18

# Copy this file to `.env` and fill in real values.
# `.env` is git-ignored and must NEVER be committed.
#
# WARNING: Vite exposes any VITE_* variable in the browser bundle. The Gemini
# API key below ships to every client visiting the site. For production, move
# this call behind a server proxy and keep the key server-side.

# Google Gemini API key (https://aistudio.google.com/apikey)
VITE_GEMINI_API_KEY=

# Gemini model name, e.g. gemini-2.5-flash, gemini-2.5-pro, gemini-1.5-flash
VITE_GEMINI_MODEL=gemini-2.5-flash

# Soft rate-limit cap (requests per minute). The client throttles outgoing
# Gemini calls to stay under this number. Default 18 — set to your actual
# quota minus a small buffer (free tier is typically 20 RPM).
VITE_GEMINI_RPM=18
